# V-Sentinel Neo4j retriever credentials (optional [neo4j] backend).
# Copy to `.env` and fill in real values. `.env` is gitignored — NEVER commit
# real credentials. Rotate the AuraDB password if it is ever exposed.

NEO4J_URI=neo4j+s://YOUR-INSTANCE.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j
