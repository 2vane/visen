# V-Sentinel configuration. Copy to `.env` and edit. `.env` is gitignored —
# NEVER commit real credentials. All values are OPTIONAL: with no .env the demo
# runs fully on local Ollama + offline BM25.
#
# Loaded automatically by the demo (api/main.py). For `vsentinel serve` or the
# library, export these vars or pass `uvicorn --env-file .env`.

# --- Models (local Ollama) ---------------------------------------------------
# VSENTINEL_OLLAMA_URL=http://localhost:11434
# VSENTINEL_CHAT_MODEL=qwen2.5
# VSENTINEL_GUARD_MODEL=qwen2.5
# Generation timeout in seconds — raise on slower GPUs.
VSENTINEL_GEN_TIMEOUT=120

# --- Access control (off by default) -----------------------------------------
# Require a key (sent as X-API-Key or `Authorization: Bearer`) on /chat + proxy:
# VSENTINEL_API_KEY=
# Per-client requests/minute (0 = unlimited):
# VSENTINEL_RATE_LIMIT=0

# --- Legal retriever ---------------------------------------------------------
# Default is offline BM25 over the packaged decree. Set to `neo4j` to use the
# legal-knowledge graph below (requires the [neo4j] extra: `uv sync --extra neo4j`).
# VSENTINEL_RETRIEVER=neo4j
# VSENTINEL_MIN_RERANK=0.3

# Retriever model device. Default "auto" (uses CUDA if present). On a small GPU
# (~6 GB) running qwen2.5-7B for chat, pin the embedder + reranker to CPU so they
# don't OOM against the chat model (retrieval is slower but safe):
# VSENTINEL_EMBED_DEVICE=cpu
# VSENTINEL_RERANK_DEVICE=cpu

# Neo4j credentials (only used when VSENTINEL_RETRIEVER=neo4j).
# Rotate the AuraDB password if it is ever exposed.
# NEO4J_URI=neo4j+s://YOUR-INSTANCE.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password-here
# NEO4J_DATABASE=neo4j
